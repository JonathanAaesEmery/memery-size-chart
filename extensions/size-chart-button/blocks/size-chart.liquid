{% comment %}
  Size Chart Button — modal med CM/IN toggle, måle-input og recommendation engine
{% endcomment %}

{% assign app_url = app.url | default: "https://memery-size-chart-production.up.railway.app" %}
{% if app_url == blank %}{% assign app_url = "https://memery-size-chart-production.up.railway.app" %}{% endif %}

{% assign accent = block.settings.accent_color | default: '#000000' %}
{% assign btn_style = block.settings.button_style | default: 'underline' %}

<div id="size-chart-wrapper-{{ block.id }}" style="margin: 8px 0;">
  <button
    id="size-chart-btn-{{ block.id }}"
    type="button"
    style="
      {% if btn_style == 'filled' %}
        background: {{ accent }};
        color: #ffffff;
        border: none;
        border-radius: 4px;
        padding: 10px 20px;
        font-size: 15px;
        font-weight: 600;
      {% elsif btn_style == 'outline' %}
        background: transparent;
        color: {{ accent }};
        border: 2px solid {{ accent }};
        border-radius: 4px;
        padding: 9px 20px;
        font-size: 15px;
        font-weight: 600;
      {% else %}
        background: none;
        border: none;
        padding: 0;
        font-size: inherit;
        text-decoration: underline;
        text-underline-offset: 3px;
        color: {{ accent }};
      {% endif %}
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: inherit;
    "
  >
    <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21.3 8.7 8.7 21.3c-.6.6-1.5.6-2.1 0L3.7 18.4c-.6-.6-.6-1.5 0-2.1L16.3 3.7c.6-.6 1.5-.6 2.1 0l2.9 2.9c.6.6.6 1.5 0 2.1z"/>
      <path d="m7.5 10.5 2 2M10.5 7.5l2 2M13.5 4.5l2 2M4.5 13.5l2 2"/>
    </svg>
    {{ block.settings.button_text | default: 'Size Guide' }}
  </button>

  <!-- Modal overlay -->
  <div
    id="size-chart-modal-{{ block.id }}"
    style="
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 9999;
      align-items: center;
      justify-content: center;
    "
  >
    <div style="
      background: #fff;
      border-radius: 8px;
      width: calc(100% - 32px);
      max-width: 680px;
      max-height: 90vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    ">
      <!-- Modal header — fast, scroller ikke med -->
      <div style="
        flex-shrink: 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid #e1e3e5;
        background: #ffffff;
      ">
        <strong id="size-chart-title-{{ block.id }}" style="font-size: 16px; color: #1a1a1a;">{{ block.settings.button_text | default: 'Size Guide' }}</strong>
        <div style="display: flex; align-items: center; gap: 12px;">
          <!-- CM/IN toggle -->
          <div id="size-chart-unit-toggle-{{ block.id }}" style="display:none; background:#f1f1f1; border-radius:20px; padding:2px; align-items:center;">
            <button id="size-chart-cm-btn-{{ block.id }}" type="button" style="border:none;cursor:pointer;border-radius:18px;padding:4px 12px;font-size:12px;font-weight:600;background:{{ accent }};color:#fff;transition:all 0.15s;">cm</button>
            <button id="size-chart-in-btn-{{ block.id }}" type="button" style="border:none;cursor:pointer;border-radius:18px;padding:4px 12px;font-size:12px;font-weight:600;background:transparent;color:#555;transition:all 0.15s;">in</button>
          </div>
          <button
            id="size-chart-close-{{ block.id }}"
            type="button"
            style="background:none;border:none;cursor:pointer;font-size:20px;line-height:1;color:#6d7175;padding:4px;"
            aria-label="Luk"
          >✕</button>
        </div>
      </div>

      <!-- Modal body — scroller indeni -->
      <div id="size-chart-body-{{ block.id }}" style="overflow-y: auto; padding: 20px; flex: 1; min-height: 0;">
        <p style="color:#6d7175;font-size:14px;">...</p>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var blockId = '{{ block.id }}';
  var appUrl = '{{ app_url }}';
  var shop = '{{ shop.permanent_domain }}';
  var productHandle = '{{ product.handle }}';
  var productId = '{{ product.id }}';
  var productTagsArray = {{ product.tags | json }};
  var vendor = encodeURIComponent('{{ product.vendor }}');
  var productType = encodeURIComponent('{{ product.type }}');
  var accentColor = '{{ accent }}';

  console.log('[Size Chart Block] blockId:', blockId, 'appUrl:', appUrl, 'shop:', shop, 'productHandle:', productHandle);

  var btn = document.getElementById('size-chart-btn-' + blockId);
  var modal = document.getElementById('size-chart-modal-' + blockId);
  var closeBtn = document.getElementById('size-chart-close-' + blockId);
  var body = document.getElementById('size-chart-body-' + blockId);
  var unitToggle = document.getElementById('size-chart-unit-toggle-' + blockId);
  var cmBtn = document.getElementById('size-chart-cm-btn-' + blockId);
  var inBtn = document.getElementById('size-chart-in-btn-' + blockId);
  var titleEl = document.getElementById('size-chart-title-' + blockId);

  if (!btn) {
    console.log('[Size Chart Block] ERROR: Button element not found!');
    return;
  }

  if (!appUrl) {
    console.log('[Size Chart Block] ERROR: appUrl is missing or empty!');
    btn.style.display = 'none';
    return;
  }

  console.log('[Size Chart Block] Initialized successfully');

  var loaded = false;
  var currentUnit = 'cm';
  var chartData = null;
  var CM_TO_IN = 0.393701;
  var T = {
    findYourSize: 'Find your size',
    findSize: 'Find size',
    enterMeasurements: 'Enter your measurements',
    findPerfectSize: 'Find your perfect size.',
    yourSizeIs: 'Your size is',
    yourRecommendedSizeIs: 'Your recommended size is',
    noSizeMatch: 'No size matches your measurements. Try a different value.',
    noExactMatch: 'No exact size match. Try adjusting your measurements.',
    loading: 'Loading...',
    couldNotLoad: 'Could not load size guide.',
    measurementsMatched: 'measurements matched',
  };

  // ── Apply button style ─────────────────────────────────────────
  function applyButtonStyle(style, color) {
    btn.style.textDecoration = 'none';
    btn.style.border = 'none';
    btn.style.borderRadius = '0';
    btn.style.padding = '0';
    btn.style.fontWeight = 'normal';
    if (style === 'filled') {
      btn.style.background = color;
      btn.style.color = '#fff';
      btn.style.borderRadius = '4px';
      btn.style.padding = '10px 20px';
      btn.style.fontWeight = '600';
      btn.style.fontSize = '15px';
    } else if (style === 'outline') {
      btn.style.background = 'transparent';
      btn.style.color = color;
      btn.style.border = '2px solid ' + color;
      btn.style.borderRadius = '4px';
      btn.style.padding = '9px 20px';
      btn.style.fontWeight = '600';
      btn.style.fontSize = '15px';
    } else {
      btn.style.background = 'none';
      btn.style.color = color;
      btn.style.textDecoration = 'underline';
      btn.style.textUnderlineOffset = '3px';
      btn.style.fontSize = 'inherit';
    }
  }

  // ── Unit toggle ────────────────────────────────────────────────
  function setUnit(unit) {
    currentUnit = unit;
    if (unit === 'cm') {
      cmBtn.style.background = accentColor; cmBtn.style.color = '#fff';
      inBtn.style.background = 'transparent'; inBtn.style.color = '#555';
    } else {
      inBtn.style.background = accentColor; inBtn.style.color = '#fff';
      cmBtn.style.background = 'transparent'; cmBtn.style.color = '#555';
    }
    if (chartData) rebuildTable();
  }

  cmBtn.addEventListener('click', function() { setUnit('cm'); });
  inBtn.addEventListener('click', function() { setUnit('in'); });

  // ── Value conversion ───────────────────────────────────────────
  function toDisplay(val) {
    if (val == null) return '';
    var num = parseFloat(val);
    if (isNaN(num)) return val;
    if (currentUnit === 'in') return (num * CM_TO_IN).toFixed(1);
    return num % 1 === 0 ? String(num) : num.toFixed(1);
  }

  function fromInput(val) {
    var num = parseFloat(val);
    if (isNaN(num)) return null;
    if (currentUnit === 'in') return num / CM_TO_IN;
    return num;
  }

  // ── Load ───────────────────────────────────────────────────────
  function loadChart() {
    var tags = Array.isArray(productTagsArray) ? productTagsArray : [];
    var tagsEncoded = tags.map(function(t) { return encodeURIComponent(String(t).trim()); }).filter(Boolean).join(',');
    var url = appUrl + '/api/size-chart?shop=' + shop
      + '&product_handle=' + encodeURIComponent(productHandle)
      + '&product_id=' + encodeURIComponent(productId)
      + '&tags=' + tagsEncoded
      + '&vendor=' + vendor
      + '&product_type=' + productType;

    console.log('[Size Chart] Fetching:', url);
    console.log('[Size Chart] Tags:', tags);

    fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        console.log('[Size Chart] Response:', data);
        if (!data.chart) { btn.style.display = 'none'; return; }
        chartData = data.chart;
        if (chartData.title) titleEl.textContent = chartData.title;

        // Apply settings from app (overrides block defaults)
        var s = data.settings || {};
        if (s.accent_color) accentColor = s.accent_color;
        if (s.button_text) btn.childNodes[btn.childNodes.length - 1].textContent = ' ' + s.button_text;
        if (s.button_style) applyButtonStyle(s.button_style, accentColor);
        if (data.translations) T = Object.assign(T, data.translations);

        // Apply default unit — normalize 'inch' → 'in'
        var defaultUnit = s.default_unit === 'inch' ? 'in' : (s.default_unit || 'cm');
        setUnit(defaultUnit);

        var hasMeasurements = (chartData.columns || []).some(function(c) { return c.columnType === 'measurement'; });
        if (hasMeasurements) {
          unitToggle.style.display = 'flex';
        }
      })
      .catch(function(err) {
        console.log('[Size Chart Block] Preload failed:', err.message);
      });
  }

  // ── Images builder ────────────────────────────────────────────
  function buildImages(images) {
    if (!images || images.length === 0) return '';
    var html = '<div style="display:flex;flex-direction:column;gap:12px;margin-bottom:20px;">';
    images.forEach(function(img) {
      html += '<img src="' + esc(img.url) + '" alt="' + esc(img.altText || '') + '" style="max-width:220px;width:100%;border-radius:6px;display:block;" />';
    });
    html += '</div>';
    return html;
  }

  // ── Main render ────────────────────────────────────────────────
  function renderAll() {
    var chart = chartData;
    var html = '';
    var images = chart.images || [];
    var imageLayout = chart.imageLayout || 'above';

    if (chart.description) {
      html += '<p style="margin:0 0 16px;color:#6d7175;font-size:14px;">' + esc(chart.description) + '</p>';
    }

    // Input section (if any column has customerInputEnabled)
    var inputCols = (chart.columns || []).filter(function(c) { return c.customerInputEnabled; });
    if (inputCols.length > 0) {
      html += buildInputSection(inputCols, chart.chartType);
    }

    // Result section (placeholder, filled by JS after recommendation)
    html += '<div id="sc-result-' + blockId + '" style="margin-bottom:16px;"></div>';

    // Size table
    if (chart.columns && chart.columns.length > 0 && chart.rows && chart.rows.length > 0) {
      html += buildTable(chart, null);
    }

    // Images always below table
    html += buildImages(images);

    if (chart.instructionsHtml) {
      html += '<div style="margin-top:20px;font-size:13px;color:#6d7175;line-height:1.6;">' + chart.instructionsHtml + '</div>';
    }

    body.innerHTML = html;

    // Wire up the find-size button
    var findBtn = document.getElementById('sc-find-btn-' + blockId);
    if (findBtn) {
      findBtn.addEventListener('click', function() { runRecommendation(); });
    }
  }

  // Rebuild only the table (called on unit toggle)
  function rebuildTable() {
    var placeholder = document.getElementById('sc-table-' + blockId);
    if (!placeholder || !chartData) return;
    var highlightRow = placeholder.getAttribute('data-highlight');
    placeholder.outerHTML = buildTable(chartData, highlightRow ? parseInt(highlightRow, 10) : null);
  }

  // ── Input section ──────────────────────────────────────────────
  function getColPlaceholder(col) {
    var mins = [], maxs = [];
    (chartData.rows || []).forEach(function(row) {
      var cell = (row.cells || []).find(function(c) { return c.columnId === col.id; });
      if (cell) {
        if (cell.minValue != null) mins.push(cell.minValue);
        if (cell.maxValue != null) maxs.push(cell.maxValue);
      }
    });
    if (mins.length && maxs.length) {
      var lo = Math.min.apply(null, mins);
      var hi = Math.max.apply(null, maxs);
      var mid = (lo + hi) / 2;
      var val = currentUnit === 'in' ? mid * CM_TO_IN : mid;
      return 'e.g. ' + (val % 1 === 0 ? String(Math.round(val)) : val.toFixed(1));
    }
    return 'e.g. ' + (currentUnit === 'in' ? '10' : '26');
  }

  function buildInputSection(inputCols, chartType) {
    var unitLabel = currentUnit === 'cm' ? 'cm' : 'in';
    var html = '<div style="background:#f9f9f9;border:1px solid #e1e3e5;border-radius:8px;padding:16px;margin-bottom:20px;">';
    html += '<p style="margin:0 0 12px;font-weight:600;font-size:14px;">' + T.findYourSize + '</p>';
    html += '<div style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;">';

    inputCols.forEach(function(col) {
      var label = col.inputLabel || col.name;
      var placeholder = getColPlaceholder(col);
      html += '<div style="display:flex;flex-direction:column;gap:4px;min-width:120px;">';
      html += '<label style="font-size:12px;color:#6d7175;" for="sc-input-' + blockId + '-' + col.id + '">' + esc(label) + ' (' + unitLabel + ')</label>';
      html += '<input id="sc-input-' + blockId + '-' + col.id + '" data-col-id="' + col.id + '" type="number" min="0" step="0.1" placeholder="' + placeholder + '" style="border:1px solid #ccc;border-radius:4px;padding:6px 10px;font-size:14px;width:100%;box-sizing:border-box;" />';
      html += '</div>';
    });

    html += '<button id="sc-find-btn-' + blockId + '" type="button" style="background:' + accentColor + ';color:#fff;border:none;border-radius:4px;padding:8px 18px;font-size:14px;cursor:pointer;white-space:nowrap;align-self:flex-end;">' + T.findSize + '</button>';
    html += '</div></div>';
    return html;
  }

  // ── Recommendation engine ──────────────────────────────────────
  function runRecommendation() {
    var chart = chartData;
    if (!chart) return;

    var inputCols = (chart.columns || []).filter(function(c) { return c.customerInputEnabled; });
    var inputs = {};
    var allFilled = true;

    inputCols.forEach(function(col) {
      var el = document.getElementById('sc-input-' + blockId + '-' + col.id);
      if (el && el.value.trim() !== '') {
        inputs[col.id] = fromInput(el.value);
      } else {
        allFilled = false;
      }
    });

    if (Object.keys(inputs).length === 0) {
      showResult(null, T.findPerfectSize);
      return;
    }

    var matchingKeyCols = (chart.columns || []).filter(function(c) { return c.isMatchingKey; });
    var resultEl = document.getElementById('sc-result-' + blockId);

    if (chart.chartType === 'footwear') {
      // Footwear: find first input column, find row where value is in range
      var firstInputColId = Object.keys(inputs)[0];
      var customerVal = inputs[firstInputColId];
      var bestRow = null;

      for (var i = 0; i < chart.rows.length; i++) {
        var row = chart.rows[i];
        var cell = (row.cells || []).find(function(c) { return c.columnId === firstInputColId; });
        if (cell && cell.minValue != null && cell.maxValue != null) {
          if (customerVal >= cell.minValue && customerVal <= cell.maxValue) {
            bestRow = row;
            break;
          }
        }
      }

      if (bestRow) {
        var sizeCols = matchingKeyCols.length > 0 ? matchingKeyCols : chart.columns.slice(0, 1);
        var sizeLabels = sizeCols.map(function(col) {
          var cell = (bestRow.cells || []).find(function(c) { return c.columnId === col.id; });
          return esc(col.name) + ': <strong>' + esc((cell && cell.value) || '–') + '</strong>';
        });
        showResult(bestRow.id, T.yourSizeIs + ' ' + sizeLabels.join(', '));
      } else {
        showResult(null, T.noSizeMatch);
      }

    } else {
      // Apparel: Max Rule — score each row
      var scores = chart.rows.map(function(row) {
        var score = 0;
        Object.keys(inputs).forEach(function(colId) {
          var val = inputs[colId];
          if (val == null) return;
          var cell = (row.cells || []).find(function(c) { return c.columnId === colId; });
          if (cell && cell.minValue != null && cell.maxValue != null) {
            if (val >= cell.minValue && val <= cell.maxValue) score++;
          }
        });
        return { row: row, score: score };
      });

      var maxScore = Math.max.apply(null, scores.map(function(s) { return s.score; }));

      if (maxScore === 0) {
        showResult(null, T.noExactMatch);
      } else {
        // Among tied rows, pick the largest (last in order)
        var best = scores.filter(function(s) { return s.score === maxScore; }).pop();
        var sizeCols = matchingKeyCols.length > 0 ? matchingKeyCols : chart.columns.slice(0, 1);
        var sizeLabels = sizeCols.map(function(col) {
          var cell = (best.row.cells || []).find(function(c) { return c.columnId === col.id; });
          return esc(col.name) + ': <strong>' + esc((cell && cell.value) || '–') + '</strong>';
        });
        var matchCount = Object.keys(inputs).length;
        var note = maxScore < matchCount ? ' (' + maxScore + '/' + matchCount + ' ' + T.measurementsMatched + ')' : '';
        showResult(best.row.id, T.yourRecommendedSizeIs + ' ' + sizeLabels.join(', ') + note);
      }
    }
  }

  function showResult(highlightRowId, message) {
    var resultEl = document.getElementById('sc-result-' + blockId);
    if (resultEl) {
      resultEl.innerHTML = '<div style="background:' + accentColor + '14;border:1px solid ' + accentColor + '44;border-radius:6px;padding:12px 16px;font-size:14px;color:' + accentColor + ';">' + message + '</div>';
    }
    // Re-render table with highlight
    var tableEl = document.getElementById('sc-table-' + blockId);
    if (tableEl && chartData) {
      tableEl.outerHTML = buildTable(chartData, highlightRowId);
    }
  }

  // ── Table builder ──────────────────────────────────────────────
  function buildTable(chart, highlightRowId) {
    var inputColIds = (chart.columns || []).filter(function(c) { return c.customerInputEnabled; }).map(function(c) { return c.id; });
    var html = '<div id="sc-table-' + blockId + '" data-highlight="' + (highlightRowId || '') + '" style="overflow-x:auto;">';
    html += '<table style="border-collapse:collapse;width:100%;font-size:13px;">';

    // Header
    html += '<thead><tr>';
    chart.columns.forEach(function(col) {
      var label = esc(col.name);
      if (col.columnType === 'measurement') {
        label = esc(col.name) + '<br><span style="color:rgba(255,255,255,0.65);font-weight:normal;font-size:11px;">(' + currentUnit + ')</span>';
      }
      html += '<th style="padding:8px 12px;background:' + accentColor + ';color:#fff;font-weight:700;text-align:left;white-space:nowrap;font-size:11px;letter-spacing:0.06em;">' + label + '</th>';
    });
    html += '</tr></thead><tbody>';

    // Rows
    chart.rows.forEach(function(row) {
      var isHighlight = highlightRowId && row.id === highlightRowId;
      var rowStyle = isHighlight
        ? 'background:' + accentColor + '18;outline:2px solid ' + accentColor + ';outline-offset:-1px;'
        : '';
      html += '<tr style="' + rowStyle + '">';
      chart.columns.forEach(function(col) {
        var cell = (row.cells || []).find(function(c) { return c.columnId === col.id; });
        var display = '';
        if (col.columnType === 'measurement' && cell) {
          if (cell.minValue != null && cell.maxValue != null) {
            display = toDisplay(cell.minValue) + '–' + toDisplay(cell.maxValue);
          } else if (cell.value != null && cell.value !== '' && !isNaN(parseFloat(cell.value))) {
            display = toDisplay(parseFloat(cell.value));
          } else if (cell.value) {
            display = esc(cell.value);
          }
        } else if (cell && cell.value) {
          display = esc(cell.value);
        }
        var cellStyle = 'padding:8px 12px;border:1px solid #e1e3e5;';
        if (isHighlight) cellStyle += 'font-weight:600;';
        html += '<td style="' + cellStyle + '">' + display + '</td>';
      });
      html += '</tr>';
    });

    html += '</tbody></table></div>';
    return html;
  }

  // ── Utils ──────────────────────────────────────────────────────
  function esc(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // ── Preload on page ready ──────────────────────────────────────
  loadChart();

  // ── Modal events ───────────────────────────────────────────────
  btn.addEventListener('click', function() {
    modal.style.display = 'flex';
    if (chartData) {
      renderAll();
    } else {
      body.innerHTML = '<p style="color:#6d7175;font-size:14px;">' + T.loading + '</p>';
      // Retry if preload hasn't finished yet
      var retries = 0;
      var wait = setInterval(function() {
        if (chartData) { clearInterval(wait); renderAll(); }
        if (++retries > 20) { clearInterval(wait); body.innerHTML = '<p style="color:#d72c0d;font-size:14px;">' + T.couldNotLoad + '</p>'; }
      }, 100);
    }
  });

  closeBtn.addEventListener('click', function() { modal.style.display = 'none'; });

  modal.addEventListener('click', function(e) {
    if (e.target === modal) modal.style.display = 'none';
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') modal.style.display = 'none';
  });
})();
</script>

{% schema %}
{
  "name": "Size Chart Button",
  "target": "section",
  "settings": []
}
{% endschema %}
